PORT=9000
ADMIN_TOKEN=changeme
SIGNAGE_DEVICE_PSK=
DB_PATH=./data/signage.db
UPLOAD_DIR=./uploads
STREAM_MONITOR_ENABLED=false
STREAM_MONITOR_INTERVAL_MS=60000
HEARTBEAT_TIMEOUT_MS=45000

# Public base URL of this controller server (used to build absolute media URLs for Pi devices).
# If not set, defaults to http://localhost:<PORT>.
# Example: https://signage.example.com
BASE_URL=

# How often the server sends PING messages to all connected devices (ms). 0 to disable.
PING_INTERVAL_MS=30000

# Grace period (ms) before marking a device offline after a WS close event.
# Allows fast reconnects to avoid a brief offline flash in the UI.
OFFLINE_GRACE_MS=8000
